# Grasp a named object, then place it at a named destination and release.
# (Internally calls the grasp skill, then carries and places.)

# === Goal ===
string  target_object              # object to pick, e.g. "mug", "apple"
string  place_target               # destination, e.g. "sink", "plate", "counter"
string  arm                        # "left" | "right"; "" or "none" = auto (arm closest to the object)
bool    top_down                   # optional: grasp the pick object from above (forwarded to /skill/grasp)
bool    visual_servo               # optional: hand-camera align before closing (forwarded to /skill/grasp)
builtin_interfaces/Duration timeout
---
# === Result ===
bool    success
string  message                    # outcome / failure reason
---
# === Feedback ===
string  phase                      # "detect" | "grasp" | "carry" | "place" | "release" | "done"
float32 progress                   # 0.0 .. 1.0
